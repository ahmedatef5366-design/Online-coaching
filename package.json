{
  "name": "coaching-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json,md}\" \"messages/**/*.json\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json,md}\" \"messages/**/*.json\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium",
    "db:bootstrap-admin": "tsx scripts/bootstrap-admin.ts",
    "check-env": "tsx scripts/check-env.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@sentry/nextjs": "^10.52.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.469.0",
    "next": "14.2.35",
    "next-intl": "^4.11.1",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.75.0",
    "recharts": "^3.8.1",
    "resend": "^6.12.3",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "overrides": {
      "postcss@<8.5.10": ">=8.5.10",
      "glob@>=10.2.0 <10.5.0": ">=10.5.0"
    }
  },
  "engines": {
    "node": ">=20.18.0 <21",
    "pnpm": ">=9.15.0"
  },
  "packageManager": "pnpm@9.15.1"
}
