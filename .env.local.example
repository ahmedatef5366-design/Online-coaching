# Supabase project credentials.
# Get these from https://app.supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=

# Browser-safe key. Use whichever variable name matches the key your project
# issues. Modern projects emit `sb_publishable_*` keys; older projects emit
# the legacy JWT `anon` key. Either name works — the code falls back from
# PUBLISHABLE_KEY to ANON_KEY automatically.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only — bypasses RLS. Never expose to the browser. Modern
# projects emit `sb_secret_*` keys; older projects emit a JWT `service_role`
# key. Either format works — set whichever your project gives you.
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL (used for password reset / OAuth redirects). In dev: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sentry error monitoring (optional). Leave blank to disable. The Next config
# only wraps Sentry when SENTRY_DSN or NEXT_PUBLIC_SENTRY_DSN is set, so
# leaving these unset keeps builds and bundles smaller.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
# Required only if you want source maps uploaded during build:
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Resend transactional email (optional). When RESEND_API_KEY is unset,
# email sends are skipped silently and form submissions still succeed.
# Get the key from https://resend.com/api-keys
RESEND_API_KEY=
# FROM address. For local testing without a verified domain, use Resend's
# onboarding sender — emails only go to the account owner's address.
# In production, replace with a verified domain like:
#   "Coaching <noreply@yourdomain.com>"
EMAIL_FROM="Coaching Platform <onboarding@resend.dev>"
# Optional reply-to (defaults to the From address).
EMAIL_REPLY_TO=

# -----------------------------------------------------------------------------
# Payments (Vodafone Cash — manual, offline)
# -----------------------------------------------------------------------------
# No online payment gateway. Payments are collected off-site (Vodafone Cash,
# InstaPay, bank transfer, etc.) and the admin records each receipt in
# /admin/payments. These env vars drive the WhatsApp deep-links the admin
# sends to clients:
#
# NEXT_PUBLIC_COACH_VODAFONE_NUMBER   the number clients should send Vodafone
#                                     Cash payments to. Shown inside the
#                                     pre-filled WhatsApp message.
# NEXT_PUBLIC_COACH_NAME              appended to the message signature.
NEXT_PUBLIC_COACH_VODAFONE_NUMBER=
NEXT_PUBLIC_COACH_NAME=

# -----------------------------------------------------------------------------
# Cloudflare Turnstile (spam CAPTCHA on /apply)
# -----------------------------------------------------------------------------
# Both must be set for the widget to render and be verified. Leaving either
# blank skips verification — useful for local development.
# Create a widget at https://dash.cloudflare.com → Turnstile.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# -----------------------------------------------------------------------------
# Plausible analytics (privacy-friendly, cookie-less)
# -----------------------------------------------------------------------------
# Leave blank to disable. When set, a small script is injected into the
# root layout and funnel events (page views) are collected by Plausible.
# NEXT_PUBLIC_PLAUSIBLE_SRC is optional — override only if you're self-hosting.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_PLAUSIBLE_SRC=
