# Supabase project credentials.
# Get these from https://app.supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=

# Browser-safe key. Use whichever variable name matches the key your project
# issues. Modern projects emit `sb_publishable_*` keys; older projects emit
# the legacy JWT `anon` key. Either name works — the code falls back from
# PUBLISHABLE_KEY to ANON_KEY automatically.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only — bypasses RLS. Never expose to the browser. Modern
# projects emit `sb_secret_*` keys; older projects emit a JWT `service_role`
# key. Either format works — set whichever your project gives you.
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL (used for password reset / OAuth redirects). In dev: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sentry error monitoring (optional). Leave blank to disable. The Next config
# only wraps Sentry when SENTRY_DSN or NEXT_PUBLIC_SENTRY_DSN is set, so
# leaving these unset keeps builds and bundles smaller.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
# Required only if you want source maps uploaded during build:
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Resend transactional email (optional). When RESEND_API_KEY is unset,
# email sends are skipped silently and form submissions still succeed.
# Get the key from https://resend.com/api-keys
RESEND_API_KEY=
# FROM address. For local testing without a verified domain, use Resend's
# onboarding sender — emails only go to the account owner's address.
# In production, replace with a verified domain like:
#   "Coaching <noreply@yourdomain.com>"
EMAIL_FROM="Coaching Platform <onboarding@resend.dev>"
# Optional reply-to (defaults to the From address).
EMAIL_REPLY_TO=
